# Rails API base URL (no trailing slash)
#   local:      http://127.0.0.1:3000
#   staging:    https://api.stg.shettar.com
#   production: https://api-v1.shettar.com
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000

